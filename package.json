{
	"name": "agiaas",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"setup": "node scripts/setup.mjs",
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"db:push": "turbo -F @agiaas/db db:push",
		"db:studio": "turbo -F @agiaas/db db:studio",
		"db:generate": "turbo -F @agiaas/db db:generate",
		"db:migrate": "turbo -F @agiaas/db db:migrate",
		"db:local": "turbo -F @agiaas/db db:local",
		"python:install": "python3.12 -m venv .venv && .venv/bin/pip install -r packages/agent/hermes_data/requirements.txt && .venv/bin/python packages/agent/scripts/patch_dependencies.py",
		"check": "biome check --write apps/ packages/ && turbo check-types"
	},
	"dependencies": {
		"@agiaas/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@agiaas/config": "workspace:*",
		"@types/node": "catalog:",
		"turbo": "^2.8.12",
		"typescript": "^5"
	},
	"packageManager": "pnpm@10.30.3"
}
