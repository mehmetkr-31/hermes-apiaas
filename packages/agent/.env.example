# Hermes Agent Configuration
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED: API Keys
# ===========================================
# Get your key from https://openrouter.ai/settings
OPENROUTER_API_KEY=

# OR use Nous Research API
# NOUS_API_KEY=

# ===========================================
# REQUIRED: Telegram Bot
# ===========================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ===========================================
# OPTIONAL: Project Paths (Auto-detected)
# ===========================================
# Root directory of the project (where local.db is)
# HERMES_PROJECT_ROOT=

# Directory for cloned repositories
# HERMES_DATA_DIR=.tmp

# Database file name
# HERMES_DB_FILE=local.db

# ===========================================
# OPTIONAL: Agent Configuration
# ===========================================
# Default model: anthropic/claude-3-5-sonnet or Hermes-4-405B
# DEFAULT_MODEL=anthropic/claude-3-5-sonnet

# Webhook server port
# WEBHOOK_PORT=8090

# ===========================================
# OPTIONAL: GitHub (for gh CLI)
# ===========================================
# GitHub Personal Access Token (for private repos)
# GH_TOKEN=

# ===========================================
# Docker Configuration
# ===========================================
# If running in Docker, uncomment and set:
# HERMES_PROJECT_ROOT=/app
# HERMES_DATA_DIR=/app/.tmp
# HERMES_DB_FILE=local.db
