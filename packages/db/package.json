{
	"name": "@agiaas/db",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"db:local": "turso dev --db-file local.db",
		"db:push": "pnpm dlx dotenv-cli -e ../../.env -- drizzle-kit push",
		"db:generate": "pnpm dlx dotenv-cli -e ../../.env -- drizzle-kit generate",
		"db:studio": "pnpm dlx dotenv-cli -e ../../.env -- drizzle-kit studio",
		"db:migrate": "pnpm dlx dotenv-cli -e ../../.env -- drizzle-kit migrate",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@agiaas/env": "workspace:*",
		"@libsql/client": "catalog:",
		"dotenv": "catalog:",
		"drizzle-orm": "catalog:",
		"libsql": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@agiaas/config": "workspace:*",
		"drizzle-kit": "^0.31.8",
		"typescript": "^5"
	}
}
